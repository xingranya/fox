{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brand-os.local/schema/proposal-create-input.v1.json",
  "title": "本地 AI 入口 Proposal 创建参数",
  "type": "object",
  "required": [
    "proposal_id",
    "proposal_kind",
    "classification",
    "after",
    "reason",
    "impact_scope",
    "evidence_refs",
    "expected_version",
    "idempotency_key"
  ],
  "properties": {
    "proposal_id": {"type": "string", "minLength": 1},
    "proposal_kind": {"enum": ["create", "update", "supersede", "link", "flag_conflict"]},
    "classification": {"type": "string", "minLength": 1},
    "subject_id": {"type": ["string", "null"], "minLength": 1},
    "before": {"type": ["object", "null"]},
    "after": {"type": "object"},
    "reason": {"type": "string", "minLength": 1},
    "impact_scope": {"type": "string", "minLength": 1},
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "supersedes_proposal_id": {"type": ["string", "null"], "minLength": 1},
    "source_meeting_item_id": {"type": ["string", "null"], "minLength": 1},
    "valid_from": {"type": ["string", "null"], "minLength": 1, "format": "date-time"},
    "valid_until": {"type": ["string", "null"], "minLength": 1, "format": "date-time"},
    "expected_version": {"type": "integer", "minimum": 0},
    "idempotency_key": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
