{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brand-os.local/schema/runtime-run.v1.json",
  "title": "Agent 运行起始留痕",
  "type": "object",
  "required": [
    "run_id",
    "schema_version",
    "project_id",
    "task_id",
    "packet_id",
    "packet_hash",
    "packet_version",
    "task_revision",
    "base_state_version",
    "role",
    "work_mode",
    "protocol_versions",
    "runtime_id",
    "runtime_version",
    "model_id",
    "model_version",
    "status",
    "started_by_kind",
    "started_by_id",
    "started_at"
  ],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "schema_version": {"const": "runtime-run.v1"},
    "project_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "packet_id": {"type": "string", "pattern": "^TP-[A-F0-9]{24}$"},
    "packet_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "packet_version": {"type": "integer", "minimum": 1},
    "task_revision": {"type": "integer", "minimum": 1},
    "base_state_version": {"type": "integer", "minimum": 0},
    "role": {"type": "string", "minLength": 1},
    "work_mode": {"enum": ["EXPLORATION", "EVALUATION", "DECISION", "EXECUTION"]},
    "protocol_versions": {"type": "object"},
    "runtime_id": {"type": "string", "minLength": 1},
    "runtime_version": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "model_version": {"type": "string", "minLength": 1},
    "status": {"const": "created"},
    "started_by_kind": {"enum": ["HUMAN", "WORKFLOW", "SYSTEM"]},
    "started_by_id": {"type": "string", "minLength": 1},
    "idempotency_key": {"type": "string", "minLength": 1},
    "request_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "started_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
