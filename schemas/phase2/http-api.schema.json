{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brand-project-os.invalid/schemas/phase2/http-api.v1.json",
  "title": "Brand Project OS HTTP API Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "openapi_version", "major_version", "minimum_supported_major", "routes", "error_statuses", "security"],
  "properties": {
    "schema_version": {"const": "http-api.v1"},
    "openapi_version": {"const": "3.1.0"},
    "major_version": {"const": 1},
    "minimum_supported_major": {"const": 1},
    "compatibility_window": {"type": "object", "additionalProperties": true},
    "health_paths": {"type": "array", "items": {"type": "string"}},
    "openapi_path": {"const": "/openapi.json"},
    "employee_prefix": {"const": "/api/v1/employee"},
    "agent_prefix": {"const": "/api/v1/agent"},
    "routes": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["method", "path", "surface", "auth"], "additionalProperties": true}},
    "error_statuses": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}},
    "limits": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1}},
    "security": {"type": "object", "additionalProperties": true},
    "deferred": {"type": "array", "items": {"type": "string"}}
  }
}
