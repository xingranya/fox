{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brand-os.local/schema/service-health.v1.json",
  "title": "Brand Project OS Service 健康报告",
  "type": "object",
  "required": [
    "schema_version",
    "check",
    "status",
    "dependencies",
    "blocking_dependencies",
    "degraded_dependencies",
    "issues"
  ],
  "properties": {
    "schema_version": {"const": "service-health.v1"},
    "check": {"enum": ["live", "ready"]},
    "status": {"enum": ["live", "ready", "not_ready"]},
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "required"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"enum": ["up", "down", "unknown", "disabled"]},
          "required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "blocking_dependencies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "degraded_dependencies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "field", "message"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "field": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
