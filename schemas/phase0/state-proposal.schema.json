{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brand-os.local/schema/state-proposal.v1.json",
  "title": "增量状态 Proposal",
  "type": "object",
  "required": ["schema_version","proposal_id","project_id","base_state_version","proposal_kind","subject_id","before","after","classification","status","reason","impact_scope","evidence_refs","conflicts","generated_by","created_at"],
  "properties": {
    "schema_version":{"const":"state-proposal.v1"},
    "proposal_id":{"type":"string","minLength":1},
    "project_id":{"type":"string","minLength":1},
    "base_state_version":{"type":"string","minLength":1},
    "proposal_kind":{"enum":["create","update","supersede","link","flag_conflict"]},
    "subject_id":{"type":["string","null"]},
    "before":{},
    "after":{},
    "classification":{"enum":["FACT","VIEW","PREFERENCE","HYPOTHESIS","OPTION","TENDENCY","TARGET_DATE","DECISION_CANDIDATE","CONSTRAINT_CANDIDATE","ACTION_CANDIDATE","OPEN"]},
    "status":{"const":"proposed"},
    "reason":{"type":"string","minLength":1},
    "impact_scope":{"type":"string","minLength":1},
    "evidence_refs":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "conflicts":{"type":"array","items":{"type":"string"}},
    "generated_by":{"type":"object","required":["kind","runtime_id"],"properties":{"kind":{"enum":["AI","WORKFLOW","HUMAN"]},"runtime_id":{"type":"string","minLength":1}},"additionalProperties":false},
    "created_at":{"type":"string","format":"date-time"}
  },
  "additionalProperties":false
}
