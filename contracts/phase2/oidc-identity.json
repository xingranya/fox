{
  "schema_version": "oidc-identity.v1",
  "flow": {
    "protocol": "openid_connect",
    "response_type": "code",
    "pkce_method": "S256",
    "client_type": "confidential_server_bff",
    "state_single_use": true,
    "nonce_required": true,
    "redirect_uri_exact_match": true
  },
  "token_validation": {
    "discovery_issuer_exact_match": true,
    "signature_required": true,
    "asymmetric_algorithms_only": true,
    "issuer_required": true,
    "audience_required": true,
    "authorized_party_checked": true,
    "expiry_checked": true,
    "issued_at_checked": true,
    "not_before_checked_when_present": true,
    "at_hash_checked_when_present": true,
    "maximum_clock_skew_seconds": 300
  },
  "employee_binding": {
    "key": ["issuer", "subject"],
    "pre_registration_required": true,
    "email_auto_binding": false,
    "disabled_employee_login_allowed": false,
    "disabled_binding_login_allowed": false
  },
  "session": {
    "opaque_random_credential": true,
    "server_stores_credential_digest_only": true,
    "tokens_encrypted_at_rest": true,
    "absolute_expiry_required": true,
    "refresh_rotation_supported": true,
    "audit_sequence_monotonic_per_session": true,
    "local_revocation_precedes_provider_revocation": true,
    "local_revocation_clears_token_ciphertext": true,
    "employee_disable_revokes_sessions": true,
    "audit_events": [
      "CREATED",
      "REFRESHED",
      "IDENTITY_ASSERTED",
      "REVOKED",
      "EXPIRED"
    ]
  },
  "authority": {
    "interactive_employee_source": "validated_oidc_session",
    "agent_identity_may_be_employee": false,
    "workflow_identity_may_be_employee": false,
    "service_identity_may_be_employee": false,
    "oidc_login_is_business_approval": false,
    "human_command_identity_requires_valid_session": true,
    "tool_permission_is_business_approval": false
  },
  "storage": {
    "postgresql_schema_version": 8,
    "raw_state_stored": false,
    "raw_nonce_stored": false,
    "raw_authorization_code_stored": false,
    "raw_session_secret_stored": false,
    "raw_tokens_stored": false
  },
  "deferred": ["project_rbac", "rls", "http_routes", "openwork_keychain"],
  "migrates_hongri_data": false
}
