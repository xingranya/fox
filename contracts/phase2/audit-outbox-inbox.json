{
  "schema_version": "audit-outbox.v1",
  "postgresql_schema_version": 11,
  "delivery_semantics": "at_least_once",
  "formal_transaction": {
    "event_audit_outbox_atomic": true,
    "approval_projection_in_same_transaction": true,
    "waits_for_derived_consumer": false,
    "outbox_failure_rolls_back_formal_write": true
  },
  "outbox_statuses": [
    "PENDING",
    "CLAIMED",
    "RETRY",
    "ACKED",
    "DEAD_LETTER"
  ],
  "inbox_statuses": [
    "IN_PROGRESS",
    "PROCESSED",
    "IGNORED",
    "FAILED"
  ],
  "consumer": {
    "claim_strategy": "for_update_skip_locked",
    "lease_required": true,
    "inbox_deduplication": true,
    "aggregate_ordering": true,
    "version_gap_blocks_later_messages": true,
    "dead_letter_audited": true,
    "may_write_formal_tables": false,
    "may_approve_formal_state": false
  },
  "replay": {
    "keeps_dead_letter_history": true,
    "processed_inbox_skips_duplicate_side_effect": true,
    "changes_project_version": false
  },
  "audit": {
    "stores_event_payload": false,
    "stores_payload_digest": true,
    "links_event_actor_project_and_version": true
  },
  "deferred": [
    "production_worker_process",
    "http_status_endpoint",
    "dify_flowlong_bisheng_consumers"
  ],
  "migrates_hongri_data": false
}
