      "stores_formal_business_state": false,
      "stores": ["workflow_run_state"],
      "replaceable": true,
      "required_for_core_readiness": false
    }
  ],
  "readiness": {
    "required_dependencies": ["postgresql", "schema", "object_storage", "oidc"],
    "optional_dependencies": [
      "openwork_runtime",
      "dify",
      "zvec",
      "open_notebook",
      "nubase",
      "flowlong"
