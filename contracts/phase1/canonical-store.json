{
  "schema_version": "canonical-store-port.v3",
  "authority": "human_confirmed_events",
  "current_implementation": "sqlite",
  "replaceable": true,
  "write_requirements": {
    "idempotency_key": true,
    "expected_version": true,
    "single_transaction_event_and_projection": true
  },
  "commands": [
    {
      "name": "create_project",
      "allowed_actor_kinds": ["HUMAN", "SYSTEM"],
      "changes_current_state": false
    },
    {
      "name": "register_source",
      "allowed_actor_kinds": ["HUMAN", "SYSTEM"],
      "changes_current_state": false
    },
    {
      "name": "import_source_batch",
      "allowed_actor_kinds": ["HUMAN", "SYSTEM"],
      "changes_current_state": false,
      "request_schema": "source-import.v1"
    },
    {
      "name": "ingest_meeting_batch",
      "allowed_actor_kinds": ["HUMAN", "AI", "WORKFLOW", "SYSTEM"],
      "changes_current_state": false,
      "request_schema": "meeting-ingest.v1"
    },
    {
      "name": "record_candidate",
      "allowed_actor_kinds": ["HUMAN", "AI", "WORKFLOW", "SYSTEM"],
      "changes_current_state": false
    },
    {
      "name": "create_proposal",
      "allowed_actor_kinds": ["HUMAN", "AI", "WORKFLOW", "SYSTEM"],
      "changes_current_state": false
    },
    {
      "name": "add_relation",
      "allowed_actor_kinds": ["HUMAN", "AI", "WORKFLOW", "SYSTEM"],
      "changes_current_state": false
    },
    {
      "name": "review_proposal",
      "allowed_actor_kinds": ["HUMAN"],
      "allowed_actor_ids": ["Fox"],
      "changes_current_state": true
    }
  ],
  "query_capabilities": [
    "source_import_report",
    "source_versions",
    "source_aliases",
    "source_gaps",
    "meeting_ingest_report"
  ],
  "forbidden_agent_operations": [
    "approve",
    "modify_and_approve",
    "reject",
    "direct_sql"
  ],
  "projection_rebuild_source": "PROPOSAL_APPROVED events from configured human reviewers",
  "backup": {
    "method": "sqlite_online_backup_api",
    "direct_live_file_copy_forbidden": true,
    "restore_checks": [
      "database_sha256",
      "quick_check",
      "store_schema_version",
      "event_count",
      "proposal_count",
      "human_action_count",
      "meeting_ingest_batch_count",
      "meeting_count",
      "meeting_segment_count",
      "meeting_item_count",
      "meeting_conflict_count",
      "project_versions",
      "state_digest",
      "meeting_digest"
    ]
  }
}
